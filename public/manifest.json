{
  "manifest_version": 3,
  "name": "AI Chat Vault",
  "description": "Export ChatGPT conversations to local Markdown from the Chrome toolbar.",
  "version": "0.1.0",
  "permissions": [],
  "action": {
    "default_title": "AI Chat Vault",
    "default_popup": "popup.html"
  },
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
